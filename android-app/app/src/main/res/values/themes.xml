<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BusTrack" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="bg_glass_card">
        <item name="android:background">@color/glass_white</item>
    </style>

    <style name="bg_circle_white">
        <item name="android:background">@drawable/bg_circle_white</item>
    </style>

</resources>